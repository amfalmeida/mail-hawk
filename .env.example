# =============================================================================
# Mail Hawk Configuration
# =============================================================================

# Application Configuration
APP_CHECK_INTERVAL=60
APP_CONFIG_SYNC_INTERVAL=300
APP_DEFAULT_INVOICE_TYPE=other
APP_RECURRENT_CHECK_INTERVAL=360

# =============================================================================
# Database Configuration
# =============================================================================

# DB_TYPE can be: sqlite, mariadb
DB_TYPE=sqlite
DB_URL=jdbc:sqlite:/share/mail_hawk/mail_hawk.db
DB_USERNAME=
DB_PASSWORD=

# =============================================================================
# Mail Configuration
# =============================================================================

MAIL_HOST=imap.gmail.com
MAIL_PORT=993
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FOLDER=INBOX
MAIL_DAYS_OLDER=30
# Comma-separated list of subject search terms (case-insensitive)
MAIL_SUBJECT_TERMS=fatura,factura,extracto,recibo
MAIL_ONLY_ATTACHMENTS=true
# Minimum message size in bytes for server-side filtering (0 = disabled)
# Messages smaller than this are skipped. Useful for filtering emails without attachments.
# Example: 10240 = 10KB minimum message size
MAIL_MIN_ATTACHMENT_SIZE=0
MAIL_PDF_PASSWORDS=
MAIL_DEBUG=false

# =============================================================================
# Google Sheets Configuration
# =============================================================================

SHEETS_ID=your-google-sheets-id
SHEETS_SHEET_NAME=values
SHEETS_CONFIG_SHEET=config
SHEETS_RECURRENT_SHEET=recurrent
SHEETS_ENCODED_CREDENTIALS=base64-encoded-service-account-json

# =============================================================================
# Actual Budget Configuration (optional)
# =============================================================================

# Enable Actual Budget integration
ACTUAL_ENABLED=false

# URL of the Actual Budget HTTP API
# If using docker-compose, use: http://actual-http-api:5007
# If running standalone, use: http://your-server:5007
ACTUAL_URL=http://actual-http-api:5007

# API key for authentication (must match API_KEY in actual-http-api service)
ACTUAL_API_KEY=your-api-key

# Budget sync ID from Actual Budget
# Find this in Actual Budget settings
ACTUAL_BUDGET_SYNC_ID=your-budget-sync-id

# Account ID for transactions
# Find this in Actual Budget account settings
ACTUAL_ACCOUNT_ID=your-account-id

# =============================================================================
# Actual Budget HTTP API Configuration
# =============================================================================
# These are used by the actual-http-api service in docker-compose.yml

# URL where Actual Budget is running
ACTUAL_BUDGET_URL=http://actual-budget:5006

# =============================================================================
# Full Docker Compose Setup
# =============================================================================
#
# To run the full stack with Actual Budget integration:
#
# 1. Create a .env file from this template:
#    cp .env.example .env
#
# 2. Edit .env with your configuration:
#    - Mail settings (IMAP credentials)
#    - Google Sheets credentials
#    - Actual Budget settings (if using)
#
# 3. Run with Docker Compose:
#    docker-compose up -d
#
# 4. (Optional) If running Actual Budget in Docker, add it to your docker-compose:
#
#    services:
#      actual-budget:
#        image: actualbudget/actual-server:latest
#        container_name: actual-budget
#        restart: unless-stopped
#        ports:
#          - "5006:5006"
#        volumes:
#          - actual-budget-data:/data
#        networks:
#          - mail-hawk-network
#
# 5. Access the services:
#    - Mail Hawk: http://localhost:8080
#    - Actual Budget HTTP API: http://localhost:5007
#    - Actual Budget (if running): http://localhost:5006
#
# =============================================================================
# Related Projects
# =============================================================================
#
# - Actual Budget HTTP API: https://github.com/amfalmeida/ha-actual-http-api
# - Actual Budget: https://actualbudget.org/
#