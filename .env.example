# Application Configuration
APP_CHECK_INTERVAL=60
APP_CONFIG_SYNC_INTERVAL=300
APP_DEFAULT_INVOICE_TYPE=other

# Database Configuration (SQLite by default)
DB_TYPE=sqlite
DB_URL=jdbc:sqlite:/share/mail_hawk/mail_hawk.db
DB_USERNAME=
DB_PASSWORD=

# Mail Configuration
MAIL_HOST=imap.gmail.com
MAIL_PORT=993
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FOLDER=INBOX
MAIL_DAYS_OLDER=30
# Comma-separated list of subject search terms (case-insensitive)
MAIL_SUBJECT_TERMS=fatura,factura,extracto,recibo
MAIL_ONLY_ATTACHMENTS=true
MAIL_MAX_EMAILS=0
MAIL_PDF_PASSWORDS=
MAIL_DEBUG=false

# Google Sheets Configuration
SHEETS_ID=your-google-sheets-id
SHEETS_SHEET_NAME=values
SHEETS_CONFIG_SHEET=config
SHEETS_ENCODED_CREDENTIALS=base64-encoded-service-account-json